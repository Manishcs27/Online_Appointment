PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/appointhub
# Local development will also work without setting MONGODB_URI because
# the backend falls back to mongodb://127.0.0.1:27017/appointhub.
# If you deploy to Render and it provides DATABASE_URL, use that instead.
# DATABASE_URL=mongodb://127.0.0.1:27017/appointhub
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
